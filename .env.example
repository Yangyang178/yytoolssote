# 网站环境配置
# API 密钥配置（可选，没有也可以运行）
DKFILE_API_KEY=
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 服务地址配置
DKFILE_API_BASE=http://dkfile.net/dkfile_api
DKFILE_AUTH_SCHEME=bearer
DEEPSEEK_BASE=https://api.deepseek.com

# Redis缓存配置（可选，不配置则使用内存缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# CDN静态资源加速（可选，留空则使用本地资源）
CDN_URL=
STATIC_VERSION=v2.0

# 对象存储配置（可选，不配置则使用本地存储）
STORAGE_TYPE=local
# STORAGE_TYPE=oss  # 改为oss启用阿里云OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=

# 邮件配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-smtp-authorization-code
SMTP_FROM=your-email@qq.com

# 安全密钥（生产环境请使用强随机密钥，可用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
SECRET_KEY=change-this-to-a-strong-random-key
